generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) models ----------

model User {
  id            String       @id @default(cuid())
  name          String?
  username      String?      @unique // chosen at onboarding, shown everywhere
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  picks         Pick[]
  ownedLeagues  League[]     @relation("LeagueOwner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Sweepstake domain ----------

enum LeagueStatus {
  OPEN // people can still join
  DRAFTED // teams dealt, locked
}

// How teams are dealt when the draw runs.
enum DrawMode {
  LUCKY_DIP // pure shuffle — someone can land both Argentina and France
  SEEDED // dealt in FIFA-ranking pots so everyone gets a fair spread
}

model League {
  id             String       @id @default(cuid())
  name           String
  inviteCode     String       @unique // short code used in invite links
  status         LeagueStatus @default(OPEN)
  // Teams dealt to each member. Null = split all 48 evenly.
  teamsPerPlayer Int?
  drawMode       DrawMode     @default(LUCKY_DIP)
  ownerId        String
  owner          User         @relation("LeagueOwner", fields: [ownerId], references: [id])
  members        Membership[]
  picks          Pick[]
  createdAt      DateTime     @default(now())
}

model Membership {
  id       String   @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime @default(now())
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
}

// Furthest stage a team has reached. Global across all leagues,
// updated from the admin panel as the tournament progresses.
enum Stage {
  GROUP // still in / went out at the group stage
  R32 // reached the round of 32
  R16
  QF
  SF
  RUNNER_UP // lost the final
  CHAMPION
}

model Team {
  id           String    @id // e.g. "ENG"
  name         String
  flag         String // emoji
  groupName    String // "A".."L"
  stage        Stage     @default(GROUP)
  eliminated   Boolean   @default(false)
  fifaRank     Int? // FIFA world ranking at tournament start — drives seeded draws
  picks        Pick[]
  homeFixtures Fixture[] @relation("HomeFixtures")
  awayFixtures Fixture[] @relation("AwayFixtures")
}

// Which round a fixture belongs to (distinct from Stage, which tracks
// how far a team got — fixtures also have a third-place match and final).
enum FixtureStage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD_PLACE
  FINAL
}

// One tournament match. Group fixtures are seeded with both teams known;
// knockout fixtures start as placeholders (homeLabel/awayLabel, e.g.
// "Winner Group C") and get real teams assigned from the admin panel.
model Fixture {
  id          String       @id @default(cuid())
  matchNumber Int          @unique // official FIFA match number 1–104
  stage       FixtureStage
  kickoff     DateTime
  venue       String
  homeTeamId  String?
  awayTeamId  String?
  homeLabel   String? // placeholder shown until homeTeamId is set
  awayLabel   String?
  homeScore   Int?
  awayScore   Int?
  homeTeam    Team?        @relation("HomeFixtures", fields: [homeTeamId], references: [id])
  awayTeam    Team?        @relation("AwayFixtures", fields: [awayTeamId], references: [id])

  @@index([kickoff])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

// One team assigned to one user within one league.
model Pick {
  id       String @id @default(cuid())
  leagueId String
  userId   String
  teamId   String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id])

  @@unique([leagueId, teamId]) // a team belongs to exactly one person per league
  @@index([leagueId, userId])
}
